        sum(case when boi_code = 3 then day_2 *
            (case when boi_code_desc = 'pama' then factor_boi_code_3_pama else factor_boi_code_3 end)else null end) as boi_3_day_2,
        sum(case when boi_code = 3 then day_3 *
            (case when boi_code_desc = 'pama' then factor_boi_code_3_pama else factor_boi_code_3 end)else null end) as boi_3_day_3,
        sum(case when boi_code = 3 then day_4 *
            (case when boi_code_desc = 'pama' then factor_boi_code_3_pama else factor_boi_code_3 end)else null end) as boi_3_day_4,
        sum(case when boi_code = 3 then day_5 *
            (case when boi_code_desc = 'pama' then factor_boi_code_3_pama else factor_boi_code_3 end)else null end) as boi_3_day_5,
        sum(case when boi_code = 3 then day_6 *
            (case when boi_code_desc = 'pama' then factor_boi_code_3_pama else factor_boi_code_3 end)else null end) as boi_3_day_6,
        sum(case when boi_code = 3 then day_7 *
            (case when boi_code_desc = 'pama' then factor_boi_code_3_pama else factor_boi_code_3 end)else null end) as boi_3_day_7,
        sum(case when boi_code = 3 then up_to_14_days *
            (case when boi_code_desc = 'pama' then factor_boi_code_3_pama else factor_boi_code_3 end)else null end) as boi_3_up_to_14_days,
        sum(case when boi_code = 3 then up_to_21_days *
            (case when boi_code_desc = 'pama' then factor_boi_code_3_pama else factor_boi_code_3 end)else null end) as boi_3_up_to_21_days,
        sum(case when boi_code = 3 then up_to_30_days *
            (case when boi_code_desc = 'pama' then factor_boi_code_3_pama else factor_boi_code_3 end)else null end) as boi_3_up_to_30_days,
        sum(case when boi_code = 3 then statement_of_balance else null end) as boi_3_statement_of_balance,

        sum(case when boi_code = 5 then day_1 else null end) as boi_5_day_1,
        sum(case when boi_code = 5 then day_2 else null end) as boi_5_day_2,
        sum(case when boi_code = 5 then day_3 else null end) as boi_5_day_3,
        sum(case when boi_code = 5 then day_4 else null end) as boi_5_day_4,
        sum(case when boi_code = 5 then day_5 else null end) as boi_5_day_5,
        sum(case when boi_code = 5 then day_6 else null end) as boi_5_day_6,
        sum(case when boi_code = 5 then day_7 else null end) as boi_5_day_7,
        sum(case when boi_code = 5 then up_to_14_days else null end) as boi_5_up_to_14_days,
        sum(case when boi_code = 5 then up_to_21_days else null end) as boi_5_up_to_21_days,
        sum(case when boi_code = 5 then up_to_30_days else null end) as boi_5_up_to_30_days,
        sum(case when boi_code = 5 then statement_of_balance else null end) as boi_5_statement_of_balance,

        sum(case when boi_code = 7 then day_1 else null end) as boi_7_day_1,
        sum(case when boi_code = 7 then day_2 else null end) as boi_7_day_2,
        sum(case when boi_code = 7 then day_3 else null end) as boi_7_day_3,
        sum(case when boi_code = 7 then day_4 else null end) as boi_7_day_4,
        sum(case when boi_code = 7 then day_5 else null end) as boi_7_day_5,
        sum(case when boi_code = 7 then day_6 else null end) as boi_7_day_6,
        sum(case when boi_code = 7 then day_7 else null end) as boi_7_day_7,
        sum(case when boi_code = 7 then up_to_14_days else null end) as boi_7_up_to_14_days,
        sum(case when boi_code = 7 then up_to_21_days else null end) as boi_7_up_to_21_days,
        sum(case when boi_code = 7 then up_to_30_days else null end) as boi_7_up_to_30_days,
        sum(case when boi_code = 7 then statement_of_balance else null end) as boi_7_statement_of_balance,

        sum(case when boi_code = 9 then day_1 else null end) as boi_9_day_1,
        sum(case when boi_code = 9 then day_2 else null end) as boi_9_day_2,
        sum(case when boi_code = 9 then day_3 else null end) as boi_9_day_3,
        sum(case when boi_code = 9 then day_4 else null end) as boi_9_day_4,
        sum(case when boi_code = 9 then day_5 else null end) as boi_9_day_5,
        sum(case when boi_code = 9 then day_6 else null end) as boi_9_day_6,
        sum(case when boi_code = 9 then day_7 else null end) as boi_9_day_7,
        sum(case when boi_code = 9 then up_to_14_days else null end) as boi_9_up_to_14_days,
        sum(case when boi_code = 9 then up_to_21_days else null end) as boi_9_up_to_21_days,
        sum(case when boi_code = 9 then up_to_30_days else null end) as boi_9_up_to_30_days,
        sum(case when boi_code = 9 then statement_of_balance else null end) as boi_9_statement_of_balance

    from report_context, final
    ),

-- Get customer loyalty scores as of the selected date.
loyalty as (
    select
        customer_id,
        loyalty_bucket,
        loyalty_score
    from table(esh_bank_il_datasets.customers.loyalty_score({{selected_date}}))
),

-- Get liquidity deposit balances and total payments as of the selected date.
liquidity_deposits as (
    select
        deposit_id,
        customer_id,
        balance,
        total_payment
    from table(esh_bank_il_datasets.fin.liquidity_deposits({{selected_date}}))
),

-- Get deposits population for boi_6 calculation
deposits_balance as (
    select
        liquidity_deposits.customer_id,
        deps.account_number,
        deps.account_id,
        deps.id          as deposit_id,
        deps.term_months as deposit_term,
        case when deps.term_months = 0  then 'current_account' -- term_month = 0 include seizures
             when deps.term_months = 3  then 'three_months_deposit'
             when deps.term_months = 12 then 'one_year_deposit'
             else null
             end as deposit_type,
        deps.end_date,
        deps.close_date,
        case when value_date <= coalesce(deps.close_date, deps.end_date)
             then deps.end_date
             else coalesce(deps.close_date, deps.end_date)
             end as coalesce_end_date,
        loyalty.loyalty_bucket,
        transaction_id,
        balance_fund,
        balance_interest,
        last_interest_transaction.value_date ,
        principal_amount                 as original_amount,
        liquidity_deposits.balance       as total_balance,
        liquidity_deposits.total_payment as total_payment,
        deps.is_active,
        deps.start_date
    from dim_deposits deps
    inner join last_interest_transaction
    on deps.id = last_interest_transaction.deposit_id
    inner join liquidity_deposits
    on deps.id = liquidity_deposits.deposit_id
    left join loyalty
    on liquidity_deposits.customer_id = loyalty.customer_id
    cross join report_context
),

-- Calculate weighted balances for early withdrawals from deposits.
early_withdraw as (
     select
        coalesce(sum(weighted_balance_1), 0) as weighted_balance_1,
        coalesce(sum(weighted_balance_2), 0) as weighted_balance_2,
        coalesce(sum(weighted_balance_3), 0) as weighted_balance_3
     from (
        select
            deposits_balance.*,
            case when loyalty_bucket = 1 then total_balance * (cust_1 / 100) else 0 end as weighted_balance_1,
            case when loyalty_bucket = 2 then total_balance * (cust_2 / 100) else 0 end as weighted_balance_2,
            case when loyalty_bucket = 3 then total_balance * (cust_3 / 100) else 0 end as weighted_balance_3
        from deposits_balance
        left join coefficient_matrix
        on deposits_balance.deposit_type = coefficient_matrix.deposit_type
        where deposit_term in (3, 12) and
            (is_active = 1 or deposits_balance.value_date < close_date) and
            coalesce_end_date >= deposits_balance.value_date + 1 and
            coefficient_matrix.deposit_type in ('one_year_deposit', 'three_months_deposit') and
            coefficient_matrix.behavior_action = 'early_withdrawal'
    )
),

-- Calculate weighted balances for current accounts. Including seizures as current accounts
current_accounts as (
    select
        coalesce(sum(weighted_balance_1), 0) as weighted_balance_1,
        coalesce(sum(weighted_balance_2), 0) as weighted_balance_2,
        coalesce(sum(weighted_balance_3), 0) as weighted_balance_3
     from (
        select distinct
            deposits_balance.*,
            sum(cust_1) over (partition by customer_id, deposit_id) as sum_private_customer_1,
            sum(cust_2) over (partition by customer_id, deposit_id) as sum_private_customer_2,
            sum(cust_3) over (partition by customer_id, deposit_id) as sum_private_customer_3,
            case when loyalty_bucket = 1 then total_balance * (sum_private_customer_1 / 100) else 0 end as weighted_balance_1,
            case when loyalty_bucket = 2 then total_balance * (sum_private_customer_2 / 100) else 0 end as weighted_balance_2,
            case when loyalty_bucket = 3 then total_balance * (sum_private_customer_3 / 100) else 0 end as weighted_balance_3
        from deposits_balance
        left join coefficient_matrix
        on deposits_balance.deposit_type = coefficient_matrix.deposit_type
        where deposit_term in (0)
              and coefficient_matrix.deposit_type in ('current_account')
              and coefficient_matrix.behavior_action in ('abandon', 'stays_in_current')
    )
),

-- Calculate weighted balances for deposits ending the next day.
one_day_end_date as (
    select
        coalesce(sum(weighted_balance_1), 0) as weighted_balance_1,
        coalesce(sum(weighted_balance_2), 0) as weighted_balance_2,
        coalesce(sum(weighted_balance_3), 0) as weighted_balance_3
     from (
            select distinct
                deposits_balance.*,
                sum(cust_1) over (partition by customer_id, deposit_id) as sum_private_customer_1,
                sum(cust_2) over (partition by customer_id, deposit_id) as sum_private_customer_2,
                sum(cust_3) over (partition by customer_id, deposit_id) as sum_private_customer_3,
                case when loyalty_bucket = 1 then total_payment * (sum_private_customer_1 / 100) else 0 end as weighted_balance_1,
                case when loyalty_bucket = 2 then total_payment * (sum_private_customer_2 / 100) else 0 end as weighted_balance_2,
                case when loyalty_bucket = 3 then total_payment * (sum_private_customer_3 / 100) else 0 end as weighted_balance_3
            from deposits_balance
            left join coefficient_matrix
            on deposits_balance.deposit_type = coefficient_matrix.deposit_type
            where deposit_term in (3, 12) and
                  coalesce_end_date = deposits_balance.value_date + 1 and
                  coefficient_matrix.deposit_type    in ('one_year_deposit', 'three_months_deposit') and
                  coefficient_matrix.behavior_action in ('abandon', 'stays_in_current')
    )
),

-- Aggregate BOI 6 day 1 balances from various components.
boi_6_day_1_agg as (
    select
        early_withdraw.weighted_balance_1   + early_withdraw.weighted_balance_2   + early_withdraw.weighted_balance_3 +
        current_accounts.weighted_balance_1 + current_accounts.weighted_balance_2 + current_accounts.weighted_balance_3 +
        one_day_end_date.weighted_balance_1 + one_day_end_date.weighted_balance_2 + one_day_end_date.weighted_balance_3
        as boi_6_day_1
    from early_withdraw, current_accounts, one_day_end_date
),

-- Calculate estimated balances for BOI 6 for days 2 to 7 and up to 30 days.
boi_6_other_buckets as (
    select distinct
        deposits_balance.*,
        case when coalesce_end_date = two_days_from_now   then total_payment else 0 end as day2_estimate_balance,
        case when coalesce_end_date = three_days_from_now then total_payment else 0 end as day3_estimate_balance,
        case when coalesce_end_date = four_days_from_now  then total_payment else 0 end as day4_estimate_balance,
        case when coalesce_end_date = five_days_from_now  then total_payment else 0 end as day5_estimate_balance,
        case when coalesce_end_date = six_days_from_now   then total_payment else 0 end as day6_estimate_balance,
        case when coalesce_end_date = seven_days_from_now then total_payment else 0 end as day7_estimate_balance,
        case when coalesce_end_date > seven_days_from_now      and coalesce_end_date <= fourteen_days_from_now   then total_payment else 0 end as up_to_14_days_estimate_balance,
        case when coalesce_end_date > fourteen_days_from_now   and coalesce_end_date <= twenty_one_days_from_now then total_payment else 0 end as up_to_21_days_estimate_balance,
        case when coalesce_end_date > twenty_one_days_from_now and coalesce_end_date <= thirty_days_from_now     then total_payment else 0 end as up_to_30_days_estimate_balance,
        sum(cust_1) over (partition by customer_id, deposit_id) as sum_private_customer_1,
        sum(cust_2) over (partition by customer_id, deposit_id) as sum_private_customer_2,
        sum(cust_3) over (partition by customer_id, deposit_id) as sum_private_customer_3
    from report_context, deposits_balance
    left join coefficient_matrix
    on deposits_balance.deposit_type = coefficient_matrix.deposit_type
    where deposit_term in (3, 12) and
          (is_active = 1 or deposits_balance.value_date < close_date) and
          coefficient_matrix.deposit_type    in ('one_year_deposit', 'three_months_deposit') and
          coefficient_matrix.behavior_action in ('abandon', 'stays_in_current')
),

-- Aggregate BOI 6 estimated balances for days 2 to 7 and up to 30 days.
boi_6_other_buckets_agg as (
    select
        coalesce(sum(
            case when loyalty_bucket = 1 then day2_estimate_balance * (sum_private_customer_1 / 100)
                 when loyalty_bucket = 2 then day2_estimate_balance * (sum_private_customer_2 / 100)
                 when loyalty_bucket = 3 then day2_estimate_balance * (sum_private_customer_3 / 100) else 0 end), 0)  as boi_6_day_2,
        coalesce(sum(
            case when loyalty_bucket = 1 then day3_estimate_balance * (sum_private_customer_1 / 100)
                 when loyalty_bucket = 2 then day3_estimate_balance * (sum_private_customer_2 / 100)
                 when loyalty_bucket = 3 then day3_estimate_balance * (sum_private_customer_3 / 100) else 0 end), 0) as boi_6_day_3,
        coalesce(sum(
            case when loyalty_bucket = 1 then day4_estimate_balance * (sum_private_customer_1 / 100)
                 when loyalty_bucket = 2 then day4_estimate_balance * (sum_private_customer_2 / 100)
                 when loyalty_bucket = 3 then day4_estimate_balance * (sum_private_customer_3 / 100) else 0 end), 0) as boi_6_day_4,
        coalesce(sum(
            case when loyalty_bucket = 1 then day5_estimate_balance * (sum_private_customer_1 / 100)
                 when loyalty_bucket = 2 then day5_estimate_balance * (sum_private_customer_2 / 100)
                 when loyalty_bucket = 3 then day5_estimate_balance * (sum_private_customer_3 / 100) else 0 end), 0) as boi_6_day_5,
        coalesce(sum(
            case when loyalty_bucket = 1 then day6_estimate_balance * (sum_private_customer_1 / 100)
                 when loyalty_bucket = 2 then day6_estimate_balance * (sum_private_customer_2 / 100)
                 when loyalty_bucket = 3 then day6_estimate_balance * (sum_private_customer_3 / 100) else 0 end), 0) as boi_6_day_6,
        coalesce(sum(
            case when loyalty_bucket = 1 then day7_estimate_balance * (sum_private_customer_1 / 100)
                 when loyalty_bucket = 2 then day7_estimate_balance * (sum_private_customer_2 / 100)
                 when loyalty_bucket = 3 then day7_estimate_balance * (sum_private_customer_3 / 100) else 0 end), 0) as boi_6_day_7,
        coalesce(sum(
            case when loyalty_bucket = 1 then up_to_14_days_estimate_balance * (sum_private_customer_1 / 100)
                 when loyalty_bucket = 2 then up_to_14_days_estimate_balance * (sum_private_customer_2 / 100)
                 when loyalty_bucket = 3 then up_to_14_days_estimate_balance * (sum_private_customer_3 / 100) else 0 end), 0) as boi_6_up_to_14_days,
